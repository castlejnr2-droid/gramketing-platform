{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'scraper worker — no app build needed'"
  },
  "deploy": {
    "startCommand": "TS_NODE_PROJECT=scripts/tsconfig.json npx ts-node -r tsconfig-paths/register --transpile-only jobs/scraper.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
