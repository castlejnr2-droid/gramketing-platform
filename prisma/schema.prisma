generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  X
  TELEGRAM
}

enum SubmissionStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PoolStatus {
  ACTIVE
  ENDED
  DISTRIBUTED
}

enum FeeCurrency {
  MGRAM
  TON
}

model User {
  id                String            @id @default(cuid())
  walletAddress     String            @unique
  username          String?
  xHandle              String?
  xAccessToken         String?
  telegramId           String?
  telegramHandle       String?
  telegramChannelUrl   String?
  telegramChatId       String?         @unique
  telegramUnlinkedAt   DateTime?
  xAccountId           String?         @unique
  xProfileImageUrl     String?
  xUnlinkedAt          DateTime?
  linkTelegramCode     String?
  linkTelegramCodeExpiry DateTime?
  createdAt         DateTime          @default(now())
  participants      PoolParticipant[]
  submissions       Submission[]
  referralsGiven    ReferralBoost[]   @relation("Referrer")
  referralsReceived ReferralBoost[]   @relation("Referred")
  telegramNotificationPrefs TelegramNotificationPrefs?
}

model TelegramNotificationPrefs {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id])
  telegramChatId           String
  notifyOutranked          Boolean  @default(true)
  notifyPoolEndingSoon     Boolean  @default(true)
  notifyRewardsDistributed Boolean  @default(true)
  notifyNewPools           Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Project {
  id                  String   @id @default(cuid())
  ownerWalletAddress  String
  name                String
  tokenSymbol         String
  jettonMasterAddress String
  logoUrl             String?
  description         String?
  xUrl                String?
  telegramUrl         String?
  createdAt           DateTime @default(now())
  pools               Pool[]
}

model Pool {
  id                   String                @id @default(cuid())
  projectId            String
  project              Project               @relation(fields: [projectId], references: [id])
  contractAddress      String?
  totalReward          String
  tokenSymbol          String
  jettonMasterAddress  String
  durationDays         Int
  rewardSlots          Int
  tier1Threshold       BigInt   @default(0)
  tier2Threshold       BigInt   @default(0)
  tier3Threshold       BigInt   @default(0)
  accessFeePaidIn      FeeCurrency
  accessFeeTxHash      String?
  campaignType         String                @default("both")
  xPostLink            String?
  telegramPostLink     String?
  xConfig              String?
  telegramConfig       String?
  startDate            DateTime
  endDate              DateTime
  status               PoolStatus            @default(ACTIVE)
  createdAt            DateTime              @default(now())
  participants         PoolParticipant[]
  submissions          Submission[]
  leaderboardSnapshots LeaderboardSnapshot[]
  platformRevenue      PlatformRevenue[]
  referralBoosts       ReferralBoost[]
  poolPosts            PoolPost[]
  adminLogs            AdminLog[]
}

model PoolParticipant {
  id                  String   @id @default(cuid())
  poolId              String
  pool                Pool     @relation(fields: [poolId], references: [id])
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  referralCode        String   @unique @default(cuid())
  referredByUserId    String?
  totalPoints         Float    @default(0)
  xPoints             Float    @default(0)
  telegramPoints      Float    @default(0)
  referralBonusPoints Float    @default(0)
  referralMultiplier  Float    @default(1.0)
  holderBoost         Float    @default(1.0)
  joinedAt            DateTime @default(now())
  poolPosts           PoolPost[]

  @@unique([poolId, userId])
}

model Submission {
  id            String           @id @default(cuid())
  poolId        String
  pool          Pool             @relation(fields: [poolId], references: [id])
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  platform      Platform
  postUrl       String
  submittedAt   DateTime         @default(now())
  lastScrapedAt DateTime?
  currentViews  Int              @default(0)
  likes         Int              @default(0)
  reposts       Int              @default(0)
  reactions     Int              @default(0)
  currentPoints Float            @default(0)
  status        SubmissionStatus @default(PENDING)
  submittedDate String

  @@unique([poolId, userId, platform, submittedDate])
}

model ReferralBoost {
  id              String   @id @default(cuid())
  referrerId      String
  referrer        User     @relation("Referrer", fields: [referrerId], references: [id])
  referredUserId  String
  referred        User     @relation("Referred", fields: [referredUserId], references: [id])
  poolId          String
  pool            Pool     @relation(fields: [poolId], references: [id])
  referredHolding BigInt   @default(0)
  boostMultiplier Float    @default(1.0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LeaderboardSnapshot {
  id         String   @id @default(cuid())
  poolId     String
  pool       Pool     @relation(fields: [poolId], references: [id])
  snapshotAt DateTime @default(now())
  rankings   Json
}

model PlatformRevenue {
  id             String      @id @default(cuid())
  poolId         String
  pool           Pool        @relation(fields: [poolId], references: [id])
  currency       FeeCurrency
  tokenAmount    String
  usdValueAtTime Float
  txHash         String?
  createdAt      DateTime    @default(now())
}

model PoolPost {
  id            String          @id @default(cuid())
  poolId        String
  pool          Pool            @relation(fields: [poolId], references: [id])
  participantId String
  participant   PoolParticipant @relation(fields: [participantId], references: [id])
  platform      Platform
  postLink      String
  views         Int             @default(0)
  likes         Int             @default(0)
  reposts       Int             @default(0)
  reactions     Int             @default(0)
  points        Float           @default(0)
  submittedAt   DateTime        @default(now())
  lastScrapedAt DateTime?
  scrapeError   String?
}

model BannedMarketer {
  id                String   @id @default(cuid())
  walletAddress     String   @unique
  reason            String?
  telegramChannel   String?
  xLink             String?
  bannedAt          DateTime @default(now())
  bannedByWallet    String
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String   // DEPLOY_CONTRACT | DISTRIBUTE_REWARDS | END_POOL | CANCEL_POOL | RESCRAPE | FEE_RECORDED | SCRAPE_ERROR | SCRAPE_CYCLE
  level     String   // info | warn | error
  poolId    String?
  pool      Pool?    @relation(fields: [poolId], references: [id], onDelete: SetNull)
  message   String
  details   Json?
  createdAt DateTime @default(now())
}

/// Cache for Twitter API v2 tweet public_metrics responses.
/// Each row stores metrics for one tweet ID for one UTC calendar day.
/// The scraper checks this before calling the API to avoid duplicate charges
/// ($0.005 per tweet fetch on the Basic plan).
model TweetMetricsCache {
  tweetId   String   @id              // numeric tweet ID string
  views     Int                       // impression_count
  likes     Int                       // like_count
  retweets  Int                       // retweet_count
  fetchedAt DateTime @default(now())  // when this row was written / last refreshed
  utcDay    String                    // YYYY-MM-DD UTC date — cache key for invalidation

  @@index([utcDay])
}
